---
const games = [
  { name: 'Pixel Mines', provider: 'PixelBet', emoji: '💣', tag: 'hot' },
  { name: 'Crypto Crash', provider: 'ChainGames', emoji: '📈', tag: 'hot' },
  { name: 'Dragon Tower', provider: 'PixelBet', emoji: '🐉', tag: 'popular' },
  { name: 'Coin Flip', provider: 'ProvablyFair', emoji: '🪙', tag: null },
  { name: 'Dice Duel', provider: 'PixelBet', emoji: '🎲', tag: null },
  { name: 'Plinko', provider: 'RetroGames', emoji: '⚡', tag: 'new' },
  { name: 'Keno', provider: 'RetroGames', emoji: '🔢', tag: null },
  { name: 'Hilo', provider: 'ChainGames', emoji: '⬆️', tag: null },
  { name: 'Blackjack', provider: 'PixelBet', emoji: '🃏', tag: 'popular' },
  { name: 'Roulette', provider: 'RetroGames', emoji: '🎡', tag: 'new' },
  { name: 'Limbo', provider: 'ChainGames', emoji: '🏃', tag: null },
  { name: 'Wheel', provider: 'PixelBet', emoji: '🎯', tag: 'hot' },
];
---
<div class="section-header">
  <h3>Featured Games</h3>
  <a class="see-all" href="#">See All</a>
</div>
<div class="games-carousel-wrapper">
  <div class="games-carousel">
    {games.map(game => (
      <div class="game-card">
        {game.tag && <span class={`game-tag ${game.tag}`}>{game.tag}</span>}
        <div class="game-card-img">{game.emoji}</div>
        <div class="game-card-body">
          <h4>{game.name}</h4>
          <span class="game-provider">{game.provider}</span>
        </div>
      </div>
    ))}
  </div>
</div>
