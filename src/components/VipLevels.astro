---
const currentLevel = 37;

const rewards = [
  '$5', '$10', '5 FS', '$15', '10 FS',
  '$20', '15 FS', '$25', '20 FS', '$50',
  '$30', '25 FS', '$35', '$40', '30 FS',
  '$60', '35 FS', '$75', '40 FS', '$100',
];

const levels = Array.from({ length: 100 }, (_, i) => {
  const num = i + 1;
  const xpRequired = num * 1000;
  const reward = rewards[(num - 1) % rewards.length];
  return {
    num,
    xpRequired,
    reward,
    completed: num < currentLevel,
    current: num === currentLevel,
    locked: num > currentLevel,
    pctFill: num < currentLevel ? 100 : num === currentLevel ? 67 : 0,
  };
});
---
<!-- VIP Levels Overlay -->
<div class="vip-overlay" id="vip-overlay">
  <div class="vip-panel">
    <div class="vip-panel-header">
      <h2>VIP Progression</h2>
      <div style="display:flex;gap:8px;align-items:center;">
        <button class="info-btn" id="tc-toggle-btn" title="Terms & Conditions">i</button>
        <button class="vip-panel-close" id="vip-panel-close">&times;</button>
      </div>
    </div>

    <div class="vip-panel-body">
      <!-- Left: Horizontal charging bars -->
      <div class="vip-levels-scroll" id="vip-levels-scroll">
        {levels.map(l => (
          <div class={`lvl-row ${l.completed ? 'completed' : ''} ${l.current ? 'current' : ''} ${l.locked ? 'locked' : ''}`}
               data-level={l.num}>
            <div class="lvl-num">{l.num}</div>
            <div class="lvl-bar-wrap">
              <div class="lvl-bar-track">
                <div class="lvl-bar-fill" style={`width:${l.pctFill}%`}></div>
              </div>
              <div class="lvl-meta">
                <span class="lvl-name">Level {l.num}</span>
                <span class="lvl-xp">{l.current ? '6,720' : l.completed ? l.xpRequired.toLocaleString() : '0'} / {l.xpRequired.toLocaleString()} XP</span>
              </div>
            </div>
            <div class="lvl-reward">{l.reward}</div>
          </div>
        ))}
      </div>

      <!-- Right: Perks + next reward -->
      <div class="vip-perks-panel">
        <div class="vip-perks-title">Level 37 — Active Perks</div>

        <div class="perk-card perk-rakeback">
          <div class="perk-top">
            <span class="perk-label">Rakeback</span>
            <span class="perk-value">12.5%</span>
          </div>
          <div class="perk-desc">12.5% of house edge returned per wager, credited instantly.</div>
        </div>

        <div class="perk-card perk-cashback">
          <div class="perk-top">
            <span class="perk-label">Cashback</span>
            <span class="perk-value">7.0%</span>
          </div>
          <div class="perk-desc">Weekly cashback on net losses. No wagering requirement.</div>
        </div>

        <div class="perk-card perk-spins">
          <div class="perk-top">
            <span class="perk-label">Free Spins</span>
            <span class="perk-value">45/mo</span>
          </div>
          <div class="perk-desc">Monthly spins at $0.20 value. Cash winnings.</div>
        </div>

        <div class="perk-card perk-claim">
          <div class="perk-top">
            <span class="perk-label">Claimable</span>
            <span class="perk-value">$182.40</span>
          </div>
          <div class="perk-desc">Accumulated from rakeback, cashback, and level-ups.</div>
        </div>

        <div class="vip-perks-title" style="margin-top:10px;">Next — Level 38</div>
        <div class="perk-card">
          <div class="perk-top">
            <span class="perk-label">Unlock</span>
            <span class="perk-value" style="color:var(--accent);">$35</span>
          </div>
          <div class="perk-desc">$35 bonus + Rakeback stays at 12.5%.</div>
        </div>
      </div>
    </div>

    <!-- T&C Panel -->
    <div class="tc-panel" id="tc-panel">
      <div class="tc-inner">
        <h4>XP Contribution by Game Category</h4>
        <p>XP is earned as a function of turnover:</p>
        <table>
          <thead><tr><th>Category</th><th>XP / $1</th><th>Rate</th></tr></thead>
          <tbody>
            <tr><td>Slots</td><td>1.0</td><td>100%</td></tr>
            <tr><td>Live Casino</td><td>0.5</td><td>50%</td></tr>
            <tr><td>Table Games</td><td>0.25</td><td>25%</td></tr>
            <tr><td>Sports</td><td>0.15</td><td>15%</td></tr>
            <tr><td>Crash / Originals</td><td>0.75</td><td>75%</td></tr>
          </tbody>
        </table>
        <h4>Rakeback</h4>
        <p>Calculated on theoretical house edge per wager, not outcome. Credited instantly. Rate increases with level.</p>
        <h4>Cashback</h4>
        <p>Weekly on net losses (Mon–Sun UTC). Credited following Monday. No wagering.</p>
        <h4>Free Spins</h4>
        <p>Credited monthly. Value and count scale with level. Winnings are cash. Unused spins expire at month end.</p>
        <h4>Progression</h4>
        <p>Levels are permanent. XP requirements increase per level. Rewards claimed manually.</p>
      </div>
    </div>
  </div>
</div>

<!-- Rakeback Popup -->
<div class="info-popup-overlay" id="rakeback-popup">
  <div class="info-popup">
    <button class="info-popup-close" data-close="rakeback-popup">&times;</button>
    <h3>Rakeback — 12.5%</h3>
    <p class="info-popup-highlight">You earn back <strong>12.5%</strong> of the house edge on every wager.</p>
    <div class="info-popup-details">
