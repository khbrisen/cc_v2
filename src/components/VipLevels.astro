</div>

<!-- Cashback Popup -->
<div class="info-popup-overlay" id="cashback-popup">
  <div class="info-popup">
    <button class="info-popup-close" data-close="cashback-popup">&times;</button>
    <h3>Cashback — 7.0%</h3>
    <p class="info-popup-highlight">You receive <strong>7.0%</strong> cashback on weekly net losses.</p>
    <div class="info-popup-details">
