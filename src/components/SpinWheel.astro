---
<div class="spin-overlay" id="spin-overlay">
  <div class="spin-modal">
    <button class="spin-close" id="spin-close">&times;</button>
    <h3>Free Spin</h3>
    <p class="spin-sub">You have 45 spins remaining</p>

    <div class="spin-wheel-container">
      <div class="spin-pointer"></div>
      <div class="spin-wheel" id="spin-wheel">
        <canvas id="spin-canvas" width="260" height="260"></canvas>
      </div>
    </div>

    <button class="spin-btn" id="spin-btn">Spin</button>
    <div class="spin-result" id="spin-result"></div>
  </div>
</div>
