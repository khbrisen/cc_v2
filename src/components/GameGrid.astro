---
const slots = [
  { name: 'Book of Dead', provider: 'Play\'n GO', emoji: '📖' },
  { name: 'Sweet Bonanza', provider: 'Pragmatic', emoji: '🍬' },
  { name: 'Gates of Olympus', provider: 'Pragmatic', emoji: '⚡' },
  { name: 'Mega Moolah', provider: 'Microgaming', emoji: '🦁' },
  { name: 'Starburst', provider: 'NetEnt', emoji: '⭐' },
  { name: 'Big Bass Splash', provider: 'Pragmatic', emoji: '🐟' },
  { name: 'Wolf Gold', provider: 'Pragmatic', emoji: '🐺' },
  { name: 'Reactoonz', provider: 'Play\'n GO', emoji: '👾' },
  { name: 'Gonzo\'s Quest', provider: 'NetEnt', emoji: '🗿' },
  { name: 'Dead or Alive', provider: 'NetEnt', emoji: '🤠' },
  { name: 'Jammin\' Jars', provider: 'Push Gaming', emoji: '🫙' },
  { name: 'Fire Joker', provider: 'Play\'n GO', emoji: '🃏' },
];
---
<div class="section-header">
  <h3>Slots</h3>
  <a class="see-all" href="#">See All</a>
</div>

<div class="category-tabs">
  <span class="cat-tab active">All</span>
  <span class="cat-tab">New</span>
  <span class="cat-tab">Popular</span>
  <span class="cat-tab">Megaways</span>
  <span class="cat-tab">Jackpot</span>
  <span class="cat-tab">Buy Bonus</span>
</div>

<div class="games-grid">
  {slots.map(game => {
    const href = game.name === 'Book of Dead' ? '/play/book-of-dead/' : '#';
    return (
      <a class="game-card" href={href} style="text-decoration:none;color:inherit;">
        <div class="game-card-img">{game.emoji}</div>
        <div class="game-card-body">
          <h4>{game.name}</h4>
          <span class="game-provider">{game.provider}</span>
        </div>
      </a>
    );
  })}
</div>
