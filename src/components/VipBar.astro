---
---
<div class="vip-section">
  <div class="vip-bar-main">
    <div class="water-tank-wrap">
      <div class="tank-level-label tank-level-top" id="tank-level-top">
        <span class="tank-level-num" id="level-next">37</span>
      </div>
      <div class="tank-container">
        <canvas id="water-canvas"></canvas>
      </div>
      <div class="tank-level-label tank-level-bottom" id="tank-level-bottom">
        <span class="tank-level-num" id="level-current">36</span>
      </div>
      <div class="water-tank-xp-label" id="xp-label">6,720 / 10,000 XP</div>
    </div>
  </div>

  <div class="vip-effects-strip">
    <div class="pill-rakeback-wrap">
      <div class="vip-effect-pill pill-rakeback" id="rakeback-trigger">
        <div class="pill-label-row">
          <span class="pill-label">Rakeback</span>
          <span class="pill-active-tag">Active</span>
          <span class="pill-boost-tag">+2%</span>
        </div>
        <div class="pill-value" id="rakeback-value">3.0%</div>
        <div class="pill-sub">Per wager</div>
        <div class="boost-timer-row"><span class="boost-timer"></span></div>
      </div>
      <button class="add-booster-btn" id="add-booster-btn">+ Add Booster</button>
    </div>

    <div class="vip-effect-pill pill-cashback" id="cashback-trigger">
      <div class="pill-label-row">
        <span class="pill-label">Cashback</span>
        <span class="pill-active-tag">Active</span>
      </div>
      <div class="pill-value" id="cashback-value">7.0%</div>
      <div class="pill-sub">Weekly</div>
    </div>

    <div class="vip-effect-pill pill-spins" id="spin-trigger">
      <div class="pill-label-row">
        <span class="pill-label">Free Spins</span>
        <span class="pill-active-tag">Active</span>
      </div>
      <div class="pill-value" id="spins-value">45</div>
      <span class="spin-cta">Spin &rarr;</span>
    </div>

    <div class="vip-effect-pill pill-claim" id="claim-trigger">
      <div class="pill-label-row">
        <span class="pill-label">Claimable</span>
        <span class="pill-active-tag">Active</span>
      </div>
      <div class="pill-value" id="claim-value">$182.40</div>
      <div class="pill-claim-actions">
        <span class="claim-cta" id="claim-cta">Claim</span>
        <span class="claim-details-cta" id="claim-details-btn">Details</span>
      </div>
    </div>
  </div>

  <div class="vip-expand-row">
    <button class="vip-expand-btn" id="vip-expand-btn">
      View All 100 VIP Levels <span class="arrow">&rarr;</span>
    </button>
  </div>
</div>
