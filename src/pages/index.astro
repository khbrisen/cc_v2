---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import VipBar from '../components/VipBar.astro';
import VipLevels from '../components/VipLevels.astro';
import SpinWheel from '../components/SpinWheel.astro';
import GamesCarousel from '../components/GamesCarousel.astro';
import GameGrid from '../components/GameGrid.astro';
---
<BaseLayout
  title="PixelCasino — Crypto Casino"
  description="Crypto casino with VIP rewards, provably fair games, and retro vibes."
>
  <div class="app-layout">
    <Sidebar />

    <div class="mobile-header">
      <span class="logo-text">PixelCasino</span>
      <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle sidebar">&#9776;</button>
    </div>

    <div class="main-content">
      <VipBar />

      <div class="ticker-bar">
        <div class="ticker-content">
          <span class="ticker-item">&#127881; <span class="win-amount">0.482 BTC</span> won on <span class="win-game">Crypto Crash</span></span>
          <span class="ticker-item">&#127942; <span class="win-amount">$12,400</span> jackpot on <span class="win-game">Mega Moolah</span></span>
          <span class="ticker-item">&#127920; <span class="win-amount">1.2 ETH</span> won on <span class="win-game">Pixel Mines</span></span>
          <span class="ticker-item">&#128142; <span class="win-amount">0.15 BTC</span> won on <span class="win-game">Dragon Tower</span></span>
          <span class="ticker-item">&#128293; <span class="win-amount">$8,300</span> on <span class="win-game">Plinko</span></span>
          <span class="ticker-item">&#9889; <span class="win-amount">3.5 SOL</span> won on <span class="win-game">Dice Duel</span></span>
          <span class="ticker-item">&#127881; <span class="win-amount">0.482 BTC</span> won on <span class="win-game">Crypto Crash</span></span>
          <span class="ticker-item">&#127942; <span class="win-amount">$12,400</span> jackpot on <span class="win-game">Mega Moolah</span></span>
          <span class="ticker-item">&#127920; <span class="win-amount">1.2 ETH</span> won on <span class="win-game">Pixel Mines</span></span>
          <span class="ticker-item">&#128142; <span class="win-amount">0.15 BTC</span> won on <span class="win-game">Dragon Tower</span></span>
          <span class="ticker-item">&#128293; <span class="win-amount">$8,300</span> on <span class="win-game">Plinko</span></span>
          <span class="ticker-item">&#9889; <span class="win-amount">3.5 SOL</span> won on <span class="win-game">Dice Duel</span></span>
        </div>
      </div>

      <GamesCarousel />

      <div class="promo-banner">
        <div class="promo-text">
          <h3>200% Deposit Match</h3>
          <p>Deposit with BTC, ETH, or SOL. Up to $5,000 bonus. Code: PIXEL200</p>
        </div>
        <button class="promo-btn">Claim Bonus</button>
      </div>

      <GameGrid />

      <footer class="site-footer">
        <p>18+ | Gamble Responsibly | Provably Fair | Crypto Only</p>
        <p>PixelCasino is a design concept. No real gambling functionality.</p>
        <div class="footer-links">
          <a href="#">Terms</a>
          <a href="#">Privacy</a>
          <a href="#">Provably Fair</a>
          <a href="#">Support</a>
        </div>
      </footer>
    </div>
  </div>

  <VipLevels />
  <SpinWheel />

  <script is:inline>
    // ── VIP Levels Overlay ────────────────────────────────────
    const expandBtn = document.getElementById('vip-expand-btn');
    const vipOverlay = document.getElementById('vip-overlay');
    const vipClose = document.getElementById('vip-panel-close');
    const pathScroll = document.getElementById('vip-path-scroll');

    function openVip() {
      vipOverlay.classList.add('open');
      document.body.style.overflow = 'hidden';
      setTimeout(() => {
        const current = pathScroll.querySelector('.vip-node.current');
        if (current) current.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 150);
    }

    function closeVip() {
      vipOverlay.classList.remove('open');
      document.body.style.overflow = '';
    }

    expandBtn.addEventListener('click', openVip);
    vipClose.addEventListener('click', closeVip);
    vipOverlay.addEventListener('click', (e) => {
      if (e.target === vipOverlay) closeVip();
    });

    // ── T&C Toggle ────────────────────────────────────────────
    const tcBtn = document.getElementById('tc-toggle-btn');
    const tcPanel = document.getElementById('tc-panel');

    tcBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      tcPanel.classList.toggle('open');
    });

    // ── Spin Wheel ────────────────────────────────────────────
    const spinTrigger = document.getElementById('spin-trigger');
    const spinOverlay = document.getElementById('spin-overlay');
    const spinClose = document.getElementById('spin-close');
    const spinBtn = document.getElementById('spin-btn');
    const spinResult = document.getElementById('spin-result');
    const spinWheel = document.getElementById('spin-wheel');
    const canvas = document.getElementById('spin-canvas');

    const prizes = [
      { label: '$5', color: '#6c5ce7' },
      { label: '$10', color: '#f5f5f7' },
      { label: '$25', color: '#a29bfe' },
      { label: '$50', color: '#f5f5f7' },
      { label: '10 FS', color: '#0984e3' },
      { label: '$100', color: '#f5f5f7' },
      { label: '25 FS', color: '#00b894' },
      { label: '$250', color: '#f5f5f7' },
    ];

    let currentAngle = 0;
    let spinning = false;

    function drawWheel() {
      const ctx = canvas.getContext('2d');
      const cx = 130, cy = 130, r = 126;
      const sliceAngle = (2 * Math.PI) / prizes.length;

      ctx.clearRect(0, 0, 260, 260);

      prizes.forEach((prize, i) => {
        const start = i * sliceAngle;
        const end = start + sliceAngle;

        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, r, start, end);
        ctx.closePath();
        ctx.fillStyle = prize.color;
        ctx.fill();
        ctx.strokeStyle = '#e8e8ea';
        ctx.lineWidth = 1;
        ctx.stroke();

        ctx.save();
        ctx.translate(cx, cy);
        ctx.rotate(start + sliceAngle / 2);
        ctx.textAlign = 'right';
        ctx.fillStyle = prize.color === '#f5f5f7' ? '#1a1a1a' : '#fff';
        ctx.font = '700 12px Inter, sans-serif';
        ctx.fillText(prize.label, r - 14, 4);
        ctx.restore();
      });

      ctx.beginPath();
      ctx.arc(cx, cy, 18, 0, 2 * Math.PI);
      ctx.fillStyle = '#6c5ce7';
      ctx.fill();
    }

    drawWheel();

    spinTrigger.addEventListener('click', () => {
      spinOverlay.classList.add('open');
      spinResult.textContent = '';
    });

    function closeSpin() {
      if (!spinning) spinOverlay.classList.remove('open');
    }

    spinClose.addEventListener('click', closeSpin);
    spinOverlay.addEventListener('click', (e) => {
      if (e.target === spinOverlay) closeSpin();
    });

    spinBtn.addEventListener('click', () => {
      if (spinning) return;
      spinning = true;
      spinBtn.disabled = true;
      spinResult.textContent = '';

      const winIndex = Math.floor(Math.random() * prizes.length);
      const sliceAngle = 360 / prizes.length;
      const targetAngle = 360 * 5 + (360 - (winIndex * sliceAngle + sliceAngle / 2));

      currentAngle += targetAngle;
      spinWheel.style.transition = 'transform 4s cubic-bezier(0.2, 0.8, 0.3, 1)';
      spinWheel.style.transform = `rotate(${currentAngle}deg)`;

      setTimeout(() => {
        spinning = false;
        spinBtn.disabled = false;
        spinResult.textContent = `You won: ${prizes[winIndex].label}!`;
      }, 4200);
    });

    // ── Claim Button ──────────────────────────────────────────
    const claimTrigger = document.getElementById('claim-trigger');
    claimTrigger.addEventListener('click', () => {
      const cta = claimTrigger.querySelector('.claim-cta');
      const val = claimTrigger.querySelector('.pill-value');
      cta.textContent = 'Claimed!';
      cta.style.background = '#00b894';
      val.textContent = '$0.00';
      setTimeout(() => {
        cta.textContent = 'Claim';
        cta.style.background = '';
        val.textContent = '$182.40';
      }, 2000);
    });

    // ── Mobile Sidebar ────────────────────────────────────────
    const mobileToggle = document.getElementById('mobile-toggle');
    if (mobileToggle) {
      mobileToggle.addEventListener('click', () => {
        document.getElementById('sidebar').classList.toggle('open');
      });
    }

    // ── ESC to close ──────────────────────────────────────────
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeVip();
        closeSpin();
      }
    });
  </script>
</BaseLayout>
