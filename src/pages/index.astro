---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import VipBar from '../components/VipBar.astro';
import VipLevels from '../components/VipLevels.astro';
import SpinWheel from '../components/SpinWheel.astro';
import GamesCarousel from '../components/GamesCarousel.astro';
import GameGrid from '../components/GameGrid.astro';
---
<BaseLayout
  title="GAS.CC — Crypto Casino"
  description="Crypto casino with VIP rewards, provably fair games."
>
  <!-- Top Header Navbar -->
  <header class="top-header">
    <div class="header-left">
      <button class="mobile-menu-btn" id="mobile-menu-btn">&#9776;</button>
      <a href="#" class="header-logo">GAS.CC</a>
      <nav class="header-nav">
        <a href="#" class="active">Casino</a>
        <a href="#">Sports</a>
        <a href="#">Live</a>
        <a href="#">Promotions</a>
      </nav>
    </div>
    <div class="header-right">
      <button class="btn-rakeback-boost">🔥 Rakeback Boost <span class="boost-timer header-boost-timer"></span></button>
      <button class="btn-add-xp" id="add-xp-btn">+ 200 XP</button>
      <button class="btn-theme-toggle" id="theme-toggle" title="Toggle accent color">◐</button>
      <button class="btn-outline">Log In</button>
      <button class="btn-primary">Register</button>
    </div>
  </header>

  <div class="app-shell">
    <Sidebar />

    <div class="main-content">
      <!-- Twinkling stars — full page background -->
      <div class="page-stars">
        <div class="page-stars-layer-1"></div>
        <div class="page-stars-layer-2"></div>
        <div class="page-stars-layer-3"></div>
      </div>

      <!-- HERO: VIP Bar in the sky -->
      <div class="hero-night-sky">
        <VipBar />
      </div>

      <div class="ticker-bar">
        <div class="ticker-content">
          <span class="ticker-item">&#127881; <span class="win-amount">0.482 BTC</span> on <span class="win-game">Crypto Crash</span></span>
          <span class="ticker-item">&#127942; <span class="win-amount">$12,400</span> on <span class="win-game">Mega Moolah</span></span>
          <span class="ticker-item">&#127920; <span class="win-amount">1.2 ETH</span> on <span class="win-game">Pixel Mines</span></span>
          <span class="ticker-item">&#128142; <span class="win-amount">0.15 BTC</span> on <span class="win-game">Dragon Tower</span></span>
          <span class="ticker-item">&#128293; <span class="win-amount">$8,300</span> on <span class="win-game">Plinko</span></span>
          <span class="ticker-item">&#9889; <span class="win-amount">3.5 SOL</span> on <span class="win-game">Dice Duel</span></span>
          <span class="ticker-item">&#127881; <span class="win-amount">0.482 BTC</span> on <span class="win-game">Crypto Crash</span></span>
          <span class="ticker-item">&#127942; <span class="win-amount">$12,400</span> on <span class="win-game">Mega Moolah</span></span>
          <span class="ticker-item">&#127920; <span class="win-amount">1.2 ETH</span> on <span class="win-game">Pixel Mines</span></span>
          <span class="ticker-item">&#128142; <span class="win-amount">0.15 BTC</span> on <span class="win-game">Dragon Tower</span></span>
          <span class="ticker-item">&#128293; <span class="win-amount">$8,300</span> on <span class="win-game">Plinko</span></span>
          <span class="ticker-item">&#9889; <span class="win-amount">3.5 SOL</span> on <span class="win-game">Dice Duel</span></span>
        </div>
      </div>

      <GamesCarousel />
      <GameGrid />

      <footer class="site-footer">
        <p>18+ | Gamble Responsibly | Provably Fair | Crypto Only</p>
        <p>GAS.CC is a design concept. No real gambling functionality.</p>
        <div class="footer-links">
          <a href="#">Terms</a>
          <a href="#">Privacy</a>
          <a href="#">Provably Fair</a>
          <a href="#">Support</a>
        </div>
      </footer>
    </div>
  </div>

  <!-- Mobile Bottom Nav -->
  <nav class="mobile-bottom-nav">
    <div class="mobile-bottom-nav-inner">
      <a href="#" class="mob-nav-item active">
        <span class="mob-icon">🏠</span> Home
      </a>
      <a href="#" class="mob-nav-item">
        <span class="mob-icon">🎮</span> Games
      </a>
      <a href="#" class="mob-nav-item">
        <span class="mob-icon">🃏</span> Live
      </a>
      <a href="#" class="mob-nav-item">
        <span class="mob-icon">👑</span> VIP
      </a>
      <a href="#" class="mob-nav-item">
        <span class="mob-icon">💰</span> Wallet
      </a>
    </div>
  </nav>

  <!-- Booster Selection Modal -->
  <div class="info-popup-overlay" id="booster-overlay">
    <div class="info-popup booster-popup">
      <button class="info-popup-close" data-close="booster-overlay">&times;</button>
      <h3>🔥 Choose a Rakeback Booster</h3>
      <p class="booster-desc">Activate a temporary boost on top of your base rakeback rate.</p>
      <div class="booster-carousel">
        <div class="booster-card" data-boost="1" data-hours="1">
          <div class="booster-badge">Starter</div>
          <div class="booster-percent">+1%</div>
          <div class="booster-duration">1 Hour</div>
          <div class="booster-detail">11.5% total rakeback</div>
          <button class="booster-activate-btn">Activate</button>
        </div>
        <div class="booster-card booster-card-popular" data-boost="2" data-hours="3">
          <div class="booster-popular-tag">Popular</div>
          <div class="booster-badge">Power</div>
          <div class="booster-percent">+2%</div>
          <div class="booster-duration">3 Hours</div>
          <div class="booster-detail">12.5% total rakeback</div>
          <button class="booster-activate-btn">Activate</button>
        </div>
        <div class="booster-card" data-boost="5" data-hours="6">
          <div class="booster-badge">Ultra</div>
          <div class="booster-percent">+5%</div>
          <div class="booster-duration">6 Hours</div>
          <div class="booster-detail">15.5% total rakeback</div>
          <button class="booster-activate-btn">Activate</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Claimable Details Modal -->
  <div class="info-popup-overlay" id="claim-details-overlay">
    <div class="info-popup claim-details-popup">
      <button class="info-popup-close" data-close="claim-details-overlay">&times;</button>
      <h3 class="info-popup-title">Claimable Breakdown</h3>
      <p class="info-popup-desc">Here's how your claimable balance is calculated:</p>
      <div class="claim-breakdown">
        <div class="breakdown-row">
          <span class="breakdown-label">🔥 Rakeback</span>
          <span class="breakdown-value breakdown-rakeback">$124.80</span>
        </div>
        <div class="breakdown-row">
          <span class="breakdown-label">💰 Cashback</span>
          <span class="breakdown-value breakdown-cashback">$57.60</span>
        </div>
        <div class="breakdown-divider"></div>
        <div class="breakdown-row breakdown-total-row">
          <span class="breakdown-label">Total Claimable</span>
          <span class="breakdown-value breakdown-total">$182.40</span>
        </div>
      </div>
      <button class="breakdown-claim-btn" id="breakdown-claim-btn">Claim $182.40</button>
    </div>
  </div>

  <VipLevels />
  <SpinWheel />

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script is:inline>
    // ── Water XP Tank + Level Up System ──────────────────────
    (function() {
      const canvas = document.getElementById('water-canvas');
      if (!canvas || typeof THREE === 'undefined') return;

      const W = 120, H = 180;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = W * dpr;
      canvas.height = H * dpr;

      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setSize(W, H);
      renderer.setPixelRatio(dpr);

      const scene = new THREE.Scene();
      const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

      const vertexShader = `
        varying vec2 vUv;
        void main() {
          vUv = uv;
          gl_Position = vec4(position, 1.0);
        }
      `;

      // Create text texture for "CCC" letters
      const textCanvas = document.createElement('canvas');
      textCanvas.width = 128;
      textCanvas.height = 192;
      const tCtx = textCanvas.getContext('2d');
      tCtx.clearRect(0, 0, 128, 192);
      tCtx.fillStyle = '#fff';
      tCtx.font = '900 52px Inter, sans-serif';
      tCtx.textAlign = 'center';
      tCtx.textBaseline = 'middle';
      tCtx.fillText('C', 64, 40);
      tCtx.fillText('C', 64, 96);
      tCtx.fillText('C', 64, 152);

      const textTexture = new THREE.CanvasTexture(textCanvas);
      textTexture.minFilter = THREE.LinearFilter;
      textTexture.magFilter = THREE.LinearFilter;

      const fragmentShader = `
        precision highp float;
        varying vec2 vUv;
        uniform float uTime;
        uniform float uFill;
        uniform float uDraining;
        uniform float uBanana;
        uniform sampler2D uTextMap;

        void main() {
          float fill = uFill;
          if (fill <= 0.001) { gl_FragColor = vec4(0.0); return; }

          float waveAmp = mix(1.0, 2.5, uDraining);

          float surfaceY = fill;
          float wave1 = sin(vUv.x * 12.0 + uTime * 2.5) * 0.015 * waveAmp;
          float wave2 = sin(vUv.x * 18.0 - uTime * 3.2) * 0.008 * waveAmp;
          float wave3 = sin(vUv.x * 7.0 + uTime * 1.8) * 0.012 * waveAmp;
          float waterLine = surfaceY + wave1 + wave2 + wave3;

          if (vUv.y < waterLine) {
            vec3 waterColor = mix(vec3(1.0), vec3(1.0, 0.882, 0.208), uBanana);

            // Sample text texture (flip Y since canvas is top-down)
            vec2 texUv = vec2(vUv.x, 1.0 - vUv.y);
            float textAlpha = texture2D(uTextMap, texUv).r;

            // Where there's a letter, draw black; otherwise draw water color
            vec3 col = mix(waterColor, vec3(0.0), textAlpha);
            gl_FragColor = vec4(col, 1.0);
          } else {
            gl_FragColor = vec4(0.0);
          }
        }
      `;

      const material = new THREE.ShaderMaterial({
        vertexShader, fragmentShader,
        uniforms: {
          uTime: { value: 0 },
          uFill: { value: 0.672 },
          uDraining: { value: 0.0 },
          uBanana: { value: 0.0 },
          uTextMap: { value: textTexture },
        },
        transparent: true,
      });

      const plane = new THREE.Mesh(new THREE.PlaneGeometry(2, 2), material);
      scene.add(plane);

      // ── XP & Perk State ────────────────────────────────
      let currentLevel = 36;
      let totalXp = 6720;
      let levelFloor = 0;
      let levelCeil = 10000;
      const xpPerLevel = 10000;
      let targetFill = (totalXp - levelFloor) / (levelCeil - levelFloor);
      let currentFill = targetFill;
      let draining = false;
      let levelingUp = false;

      const minFill = 200 / xpPerLevel;

      // Perk values
      let rakeback = 3.0;     // starts at 3%, +1% per level
      let cashback = 7.0;     // +0.5% per level
      let freeSpins = 45;     // +10 per level

      const xpLabel = document.getElementById('xp-label');
      const levelCurrent = document.getElementById('level-current');
      const levelNext = document.getElementById('level-next');
      const addXpBtn = document.getElementById('add-xp-btn');
      const rakebackEl = document.getElementById('rakeback-value');
      const cashbackEl = document.getElementById('cashback-value');
      const spinsEl = document.getElementById('spins-value');

      function updateLabel() {
        xpLabel.textContent = totalXp.toLocaleString() + ' / ' + levelCeil.toLocaleString() + ' XP';
      }

      // Generic number roll animation
      function rollNumber(el, from, to, duration, formatter) {
        const startTime = performance.now();
        function tick(now) {
          const progress = Math.min((now - startTime) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const val = from + (to - from) * eased;
          el.textContent = formatter(val);
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }

      function rollDenominator(from, to, duration) {
        const startTime = performance.now();
        function tick(now) {
          const progress = Math.min((now - startTime) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const val = Math.round(from + (to - from) * eased);
          xpLabel.textContent = totalXp.toLocaleString() + ' / ' + val.toLocaleString() + ' XP';
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }

      function doLevelUp() {
        levelingUp = true;
        draining = true;
        targetFill = 0;

        const curNum = levelCurrent;
        const nextNum = levelNext;

        curNum.classList.add('shift-out-bottom');
        nextNum.classList.add('shift-out-bottom');

        const oldCeil = levelCeil;
        currentLevel++;
        levelFloor = levelCeil;
        levelCeil = levelFloor + xpPerLevel;

        // Roll denominator
        rollDenominator(oldCeil, levelCeil, 1200);

        // Roll perk values simultaneously
        const oldRakeback = rakeback;
        const oldCashback = cashback;
        const oldSpins = freeSpins;
        rakeback += 1.0;
        cashback += 0.5;
        freeSpins += 10;

        rollNumber(rakebackEl, oldRakeback, rakeback, 1000, v => v.toFixed(1) + '%');
        rollNumber(cashbackEl, oldCashback, cashback, 1000, v => v.toFixed(1) + '%');
        rollNumber(spinsEl, oldSpins, freeSpins, 1000, v => Math.round(v).toString());

        // After labels slide out, swap and slide new ones in
        setTimeout(() => {
          curNum.textContent = currentLevel;
          nextNum.textContent = currentLevel + 1;

          curNum.classList.remove('shift-out-bottom');
          nextNum.classList.remove('shift-out-bottom');
          nextNum.classList.add('shift-in-top');
          void nextNum.offsetWidth;
          void curNum.offsetWidth;

          curNum.classList.add('shift-enter');
          nextNum.classList.remove('shift-in-top');
          nextNum.classList.add('shift-enter');

          setTimeout(() => {
            curNum.classList.remove('shift-enter');
            nextNum.classList.remove('shift-enter');
          }, 650);
        }, 600);
      }

      function onDrainComplete() {
        draining = false;
        currentFill = 0;
        targetFill = minFill;
        updateLabel();
        levelingUp = false;
      }

      // Add XP button
      addXpBtn.addEventListener('click', () => {
        if (levelingUp) return;

        totalXp = Math.min(totalXp + 200, levelCeil);
        updateLabel();

        if (totalXp >= levelCeil) {
          doLevelUp();
        } else {
          const progress = (totalXp - levelFloor) / (levelCeil - levelFloor);
          targetFill = Math.max(progress, minFill);
        }
      });

      // Render loop
      function animate(t) {
        requestAnimationFrame(animate);
        material.uniforms.uTime.value = t * 0.001;
        material.uniforms.uBanana.value = document.documentElement.classList.contains('theme-banana') ? 1.0 : 0.0;
        material.uniforms.uDraining.value = draining ? 1.0 : 0.0;

        // Smooth fill interpolation
        if (draining) {
          currentFill = Math.max(0, currentFill - 0.012);
          if (currentFill <= 0.001) {
            currentFill = 0;
            onDrainComplete();
          }
        } else {
          const diff = targetFill - currentFill;
          if (Math.abs(diff) > 0.001) {
            currentFill += diff * 0.08;
          } else {
            currentFill = targetFill;
          }
        }

        material.uniforms.uFill.value = currentFill;
        renderer.render(scene, camera);
      }
      requestAnimationFrame(animate);
    })();

    // ── Boost Countdown Timer ─────────────────────────────────
    let boostEnd = Date.now() + (2 * 3600 + 47 * 60 + 33) * 1000;
    const timerEls = document.querySelectorAll('.boost-timer');

    function updateBoostTimers() {
      const remaining = Math.max(0, boostEnd - Date.now());
      const h = Math.floor(remaining / 3600000);
      const m = Math.floor((remaining % 3600000) / 60000);
      const s = Math.floor((remaining % 60000) / 1000);
      const text = h > 0
        ? `${h}h ${String(m).padStart(2,'0')}m ${String(s).padStart(2,'0')}s`
        : `${m}m ${String(s).padStart(2,'0')}s`;
      timerEls.forEach(el => el.textContent = text);
      if (remaining > 0) requestAnimationFrame(updateBoostTimers);
    }
    updateBoostTimers();

    // ── Booster Selection ─────────────────────────────────────
    const addBoosterBtn = document.getElementById('add-booster-btn');
    const boostTag = document.querySelector('.pill-boost-tag');
    const rakebackValue = document.querySelector('.pill-rakeback .pill-value');

    addBoosterBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      openPopup('booster-overlay');
    });

    document.querySelectorAll('.booster-activate-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const card = btn.closest('.booster-card');
        const boostPct = parseInt(card.dataset.boost);
        const hours = parseInt(card.dataset.hours);

        boostEnd = Date.now() + hours * 3600 * 1000;
        updateBoostTimers();

        boostTag.textContent = '🔥 +' + boostPct + '%';
        rakebackValue.textContent = (10.5 + boostPct).toFixed(1) + '%';

        btn.textContent = 'Activated!';
        btn.style.background = '#fff';
        btn.style.color = '#000';

        setTimeout(() => {
          closePopup('booster-overlay');
          btn.textContent = 'Activate';
          btn.style.background = '';
          btn.style.color = '';
        }, 800);
      });
    });

    // ── VIP Levels Overlay ────────────────────────────────────
    const expandBtn = document.getElementById('vip-expand-btn');
    const vipOverlay = document.getElementById('vip-overlay');
    const vipClose = document.getElementById('vip-panel-close');
    const levelsScroll = document.getElementById('vip-levels-scroll');

    function openVip() {
      vipOverlay.classList.add('open');
      document.body.style.overflow = 'hidden';
      setTimeout(() => {
        const cur = levelsScroll.querySelector('.vp-node.current');
        if (cur) cur.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 150);
    }
    function closeVip() { vipOverlay.classList.remove('open'); document.body.style.overflow = ''; }

    expandBtn.addEventListener('click', openVip);
    vipClose.addEventListener('click', closeVip);
    vipOverlay.addEventListener('click', (e) => { if (e.target === vipOverlay) closeVip(); });

    // ── T&C Toggle ────────────────────────────────────────────
    document.getElementById('tc-toggle-btn').addEventListener('click', (e) => {
      e.stopPropagation();
      document.getElementById('tc-panel').classList.toggle('open');
    });

    // ── Rakeback / Cashback Popups ────────────────────────────
    function openPopup(id) { document.getElementById(id).classList.add('open'); }
    function closePopup(id) { document.getElementById(id).classList.remove('open'); }

    document.getElementById('rakeback-trigger').addEventListener('click', () => openPopup('rakeback-popup'));
    document.getElementById('cashback-trigger').addEventListener('click', () => openPopup('cashback-popup'));

    document.querySelectorAll('.info-popup-close').forEach(btn => {
      btn.addEventListener('click', () => closePopup(btn.dataset.close));
    });
    document.querySelectorAll('.info-popup-overlay').forEach(overlay => {
      overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.remove('open'); });
    });

    // ── Spin Wheel ────────────────────────────────────────────
    const spinTrigger = document.getElementById('spin-trigger');
    const spinOverlay = document.getElementById('spin-overlay');
    const spinClose = document.getElementById('spin-close');
    const spinBtn = document.getElementById('spin-btn');
    const spinResult = document.getElementById('spin-result');
    const spinWheel = document.getElementById('spin-wheel');
    const spinCanvas = document.getElementById('spin-canvas');

    const prizes = [
      { label: '$5', color: '#1a1a1a' },
      { label: '$10', color: '#0d0d0d' },
      { label: '$25', color: '#1a1a1a' },
      { label: '$50', color: '#0d0d0d' },
      { label: '10 FS', color: '#1a1a1a' },
      { label: '$100', color: '#0d0d0d' },
      { label: '25 FS', color: '#1a1a1a' },
      { label: '$250', color: '#0d0d0d' },
    ];

    let currentAngle = 0, spinning = false;

    function drawWheel() {
      const ctx = spinCanvas.getContext('2d');
      const cx = 130, cy = 130, r = 126, sliceAngle = (2 * Math.PI) / prizes.length;
      ctx.clearRect(0, 0, 260, 260);
      prizes.forEach((p, i) => {
        const s = i * sliceAngle, e = s + sliceAngle;
        ctx.beginPath(); ctx.moveTo(cx, cy); ctx.arc(cx, cy, r, s, e); ctx.closePath();
        ctx.fillStyle = p.color; ctx.fill();
        ctx.strokeStyle = 'rgba(255,255,255,0.08)'; ctx.lineWidth = 1; ctx.stroke();
        ctx.save(); ctx.translate(cx, cy); ctx.rotate(s + sliceAngle / 2);
        ctx.textAlign = 'right';
        ctx.fillStyle = '#ffffff';
        ctx.font = '700 11px Inter, sans-serif';
        ctx.fillText(p.label, r - 12, 4); ctx.restore();
      });
      ctx.beginPath(); ctx.arc(cx, cy, 16, 0, 2 * Math.PI);
      ctx.fillStyle = '#ffffff'; ctx.fill();
    }
    drawWheel();

    spinTrigger.addEventListener('click', () => { spinOverlay.classList.add('open'); spinResult.textContent = ''; });
    function closeSpin() { if (!spinning) spinOverlay.classList.remove('open'); }
    spinClose.addEventListener('click', closeSpin);
    spinOverlay.addEventListener('click', (e) => { if (e.target === spinOverlay) closeSpin(); });

    spinBtn.addEventListener('click', () => {
      if (spinning) return;
      spinning = true; spinBtn.disabled = true; spinResult.textContent = '';
      const wi = Math.floor(Math.random() * prizes.length);
      const sa = 360 / prizes.length;
      currentAngle += 360 * 5 + (360 - (wi * sa + sa / 2));
      spinWheel.style.transition = 'transform 4s cubic-bezier(0.2, 0.8, 0.3, 1)';
      spinWheel.style.transform = `rotate(${currentAngle}deg)`;
      setTimeout(() => { spinning = false; spinBtn.disabled = false; spinResult.textContent = `You won: ${prizes[wi].label}!`; }, 4200);
    });

    // ── Claim → Animate funds to wallet ───────────────────────
    const claimTrigger = document.getElementById('claim-trigger');
    const claimValue = document.getElementById('claim-value');
    const claimCta = document.getElementById('claim-cta');
    const balanceEl = document.getElementById('balance-amount');
    const breakdownClaimBtn = document.getElementById('breakdown-claim-btn');
    let currentBalance = 4207.83;
    const claimAmount = 182.40;

    function doClaim() {
      if (claimCta.textContent === 'Claimed!') return;

      closePopup('claim-details-overlay');

      const claimRect = claimTrigger.getBoundingClientRect();
      const balanceRect = balanceEl.getBoundingClientRect();

      const fly = document.createElement('div');
      fly.className = 'balance-fly';
      fly.textContent = '+$182.40';
      fly.style.left = claimRect.left + claimRect.width / 2 - 30 + 'px';
      fly.style.top = claimRect.top + 'px';
      document.body.appendChild(fly);

      const dx = balanceRect.left - claimRect.left;
      const dy = balanceRect.top - claimRect.top;
      fly.animate([
        { transform: 'translate(0, 0) scale(1)', opacity: 1 },
        { transform: `translate(${dx}px, ${dy}px) scale(0.6)`, opacity: 0.3 }
      ], { duration: 700, easing: 'ease-in', fill: 'forwards' });

      claimCta.textContent = 'Claimed!';
      claimCta.style.background = '#fff';
      claimCta.style.color = '#000';
      claimValue.textContent = '$0.00';

      setTimeout(() => {
        fly.remove();
        balanceEl.classList.add('adding');
        const target = currentBalance + claimAmount;
        const start = currentBalance;
        const duration = 600;
        const startTime = performance.now();

        function tick(now) {
          const elapsed = now - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const val = start + (target - start) * eased;
          balanceEl.textContent = '$' + val.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
          if (progress < 1) requestAnimationFrame(tick);
          else {
            currentBalance = target;
            setTimeout(() => balanceEl.classList.remove('adding'), 400);
          }
        }
        requestAnimationFrame(tick);
      }, 650);

      setTimeout(() => {
        claimCta.textContent = 'Claim';
        claimCta.style.background = '';
        claimCta.style.color = '';
        claimValue.textContent = '$182.40';
        currentBalance = 4207.83;
        balanceEl.textContent = '$4,207.83';
      }, 3500);
    }

    claimTrigger.addEventListener('click', doClaim);
    breakdownClaimBtn.addEventListener('click', doClaim);

    // ── Claim Details Modal ─────────────────────────────────────
    const claimDetailsBtn = document.getElementById('claim-details-btn');
    claimDetailsBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      openPopup('claim-details-overlay');
    });

    // ── Mobile Sidebar ────────────────────────────────────────
    document.getElementById('mobile-menu-btn').addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('open');
    });

    // ── ESC ───────────────────────────────────────────────────
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeVip(); closeSpin();
        document.querySelectorAll('.info-popup-overlay.open').forEach(o => o.classList.remove('open'));
      }
    });

    // ── Theme Toggle (White ↔ Banana Yellow) ──────────────────
    const themeToggle = document.getElementById('theme-toggle');
    themeToggle.addEventListener('click', () => {
      document.documentElement.classList.toggle('theme-banana');
    });
  </script>
</BaseLayout>
