---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Book of Dead — GAS.CC"
  description="Play Book of Dead by Play'n GO on GAS.CC"
>
  <header class="top-header">
    <div class="header-left">
      <a href="/" class="header-logo">GAS.CC</a>
    </div>
    <div class="header-right">
      <button class="btn-outline">Log In</button>
      <button class="btn-primary">Register</button>
    </div>
  </header>

  <div style="padding-top: var(--header-h);">
    <div class="game-page">
      <!-- Game toolbar -->
      <div class="game-page-top">
        <a href="/" class="game-back">&larr; Back</a>
        <span class="game-page-title">Book of Dead</span>
        <span class="game-page-provider">Play'n GO</span>
      </div>

      <!-- Game iframe area -->
      <div class="game-page-iframe">
        <div class="game-placeholder">
          <div>📖</div>
          <p>Game loads here (iframe placeholder)</p>
        </div>
      </div>

      <!-- Mini VIP strip -->
      <div class="game-mini-vip">
        <div class="mini-vip-pill mini-vip-rakeback">
          <span class="mini-vip-label">Rakeback</span>
          <span class="mini-vip-value mini-vip-green">12.5%</span>
        </div>
        <div class="mini-vip-pill mini-vip-cashback">
          <span class="mini-vip-label">Cashback</span>
          <span class="mini-vip-value mini-vip-blue">7.0%</span>
        </div>
        <div class="mini-vip-pill mini-vip-claimable">
          <span class="mini-vip-label">Claimable</span>
          <span class="mini-vip-value mini-vip-orange" id="mini-claim-value">$182.40</span>
          <div class="mini-vip-actions">
            <span class="mini-claim-btn" id="mini-claim-btn">Claim</span>
            <span class="mini-details-btn" id="mini-details-btn">Details</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Claimable Details Modal -->
  <div class="info-popup-overlay" id="claim-details-overlay">
    <div class="info-popup claim-details-popup">
      <button class="info-popup-close" data-close="claim-details-overlay">&times;</button>
      <h3>Claimable Breakdown</h3>
      <p class="info-popup-desc">Here's how your claimable balance is calculated:</p>
      <div class="claim-breakdown">
        <div class="breakdown-row">
          <span class="breakdown-label">🔥 Rakeback</span>
          <span class="breakdown-value breakdown-rakeback">$124.80</span>
        </div>
        <div class="breakdown-row">
          <span class="breakdown-label">💰 Cashback</span>
          <span class="breakdown-value breakdown-cashback">$57.60</span>
        </div>
        <div class="breakdown-divider"></div>
        <div class="breakdown-row breakdown-total-row">
          <span class="breakdown-label">Total Claimable</span>
          <span class="breakdown-value breakdown-total">$182.40</span>
        </div>
      </div>
      <button class="breakdown-claim-btn" id="breakdown-claim-btn">Claim $182.40</button>
    </div>
  </div>

  <script is:inline>
    // ── Popup helpers ─────────────────────────────────────────
    function openPopup(id) { document.getElementById(id).classList.add('open'); }
    function closePopup(id) { document.getElementById(id).classList.remove('open'); }

    document.querySelectorAll('.info-popup-close').forEach(btn => {
      btn.addEventListener('click', () => closePopup(btn.dataset.close));
    });
    document.querySelectorAll('.info-popup-overlay').forEach(overlay => {
      overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.remove('open'); });
    });

    // ── Claim ─────────────────────────────────────────────────
    const miniClaimValue = document.getElementById('mini-claim-value');
    const miniClaimBtn = document.getElementById('mini-claim-btn');
    const breakdownClaimBtn = document.getElementById('breakdown-claim-btn');

    function doClaim() {
      if (miniClaimBtn.textContent === 'Claimed!') return;
      closePopup('claim-details-overlay');
      miniClaimBtn.textContent = 'Claimed!';
      miniClaimBtn.style.background = '#00b894';
      miniClaimValue.textContent = '$0.00';
      setTimeout(() => {
        miniClaimBtn.textContent = 'Claim';
        miniClaimBtn.style.background = '';
        miniClaimValue.textContent = '$182.40';
      }, 2500);
    }

    miniClaimBtn.addEventListener('click', (e) => { e.stopPropagation(); doClaim(); });
    breakdownClaimBtn.addEventListener('click', doClaim);

    // ── Details ───────────────────────────────────────────────
    document.getElementById('mini-details-btn').addEventListener('click', (e) => {
      e.stopPropagation();
      openPopup('claim-details-overlay');
    });

    // ── ESC ───────────────────────────────────────────────────
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('.info-popup-overlay.open').forEach(o => o.classList.remove('open'));
      }
    });
  </script>
</BaseLayout>
